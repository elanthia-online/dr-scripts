class Default
  attr_accessor :base_tab
  
  SOLID_LINE  = "________________________________________________________________________________\n"
  
  def self.to_base_info(info_obj)
    info_hash = nil
	
	if info_obj.is_a?(Hash)
	  info_hash = info_obj.transform_keys(&:to_sym)
	  return info_hash
	end
    
	if info_obj.respond_to?(:base_info)
	  info_hash = info_obj.base_info
	  return info_hash
	end
    
    info_hash = to_hash(info_obj)
	info_hash
  end

  def self.has_keys?(info, key_list)
    info_hash = to_base_info(info)
    key_list.all? { |key| info_hash.key?(key) && !info_hash[key].nil? }
  end

  def self.up_tabs!(tab_objs, amount = 1)
    tab_objs.each { |obj| obj.tab_up!(amount) if obj.respond_to?(:tab_up!) }
    tab_objs
  end
  
  def self.tab_parent!(parent, children)
	offspring = Array(children)
    
	return nil unless parent.respond_to?(:base_tab=)
    return nil unless offspring.all? { |child| child.respond_to?(:base_tab=) }

    parent_tab = parent.base_tab || 0
    child_tab = parent_tab + 1
  
    offspring.each { |child| child.base_tab = child_tab }
    return parent, children
  end
  
  def self.as_instance_variable(raw_var)
    var_str = raw_var.to_s
	return "@#{var_str}".to_sym unless var_str.include?("@")
	raw_var.to_sym
  end
  
  def self.as_hash_key(raw_var)
    return raw_var.to_s.delete("@").to_sym
  end
  
  def self.to_hash(info_obj, exclude = [])
    return {} unless info_obj.respond_to?(:instance_variables)
	
	excluded_variables = [:@base_tab]
	unless exclude.empty?
	  exclude.each do |excl_var|
	    excluded_variables << as_instance_variable(excl_var)
	  end
	end
	
    info_hash = info_obj.instance_variables.each_with_object({}) do |var, hash|
      next if excluded_variables.include?(var)
	  key = as_hash_key(var)
      hash[key] = info_obj.instance_variable_get(var)
    end

    info_hash
  end

  def self.clean_str(raw_arg)
    return "" if raw_arg.nil?
    "#{raw_arg.to_s.downcase.strip}"
  end
  
  def initialize
    @base_tab = 0
	@hidden_attributes = [:base_tab]
  end

  # Helper to get the current indentation string
  def tab
    "      " * (@base_tab || 0)
  end

  # Helper for newline + current indentation
  def nest_tab
    "\n" + tab
  end

  def are_children!(tab_objs)
    self.class.tab_parent!(self, tab_objs)
  end

  # Increases the current object's tab level
  def tab_up!(amount = 1)
    @base_tab = (@base_tab || 0) + amount
  end

  # Joins an array of strings using the nested indentation
  def nest_string(str_arr = [])
    str_arr.join(nest_tab)
  end
  
  # Converts elements to strings and joins them with nested indentation
  def nest_array(arr = [])
    arr.map { |element| "#{element}" }.join(nest_tab)
  end
  
  def to_h(exclude = @hidden_attributes)
    self.class.to_hash(self, exclude)
  end
  
  # Updated to_s using your nesting logic
  def to_s
    data = to_h
    
    lines = data.map do |key, val|
      "#{key}: #{val.inspect}"
    end
    
    header = "#{tab}<#{self.class.name}>"
    body = nest_string(lines.map { |l| "  " + l })
    footer = "#{tab}</#{self.class.name}>"
    
    "#{header}\n#{body}\n#{footer}"
  end


end

