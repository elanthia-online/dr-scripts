  class BaseStock < Default
    # Assuming BASE_CRAFTING is defined globally elsewhere
    @@base_stocks = BASE_CRAFTING.stock.freeze
    
    attr_reader :raw_stock_data
    attr_reader :base_key, :name, :order_id, :volume, :value
	
	def self._attr_key_search(query_name)
      # Assuming Data::BASE_PARTS and clean_str are defined in the broader scope
      source_database = @@base_stocks
	  query_str = clean_str(query_name)
      
	  exact_matches = []
      close_matches = []

      # Iterate through the entire database
      source_database.each do |base_key, base_data|
 
        key_str = clean_str(base_key)
		attr_str = clean_str(base_data['stock-name'])		
		
		exact_key = (key_str == query_str)
		exact_attr = (attr_str == query_str)

		exact_match = exact_key || exact_attr
		
		close_key = key_str.include?(query_str)
		close_attr = attr_str.include?(query_str)
		
		close_match = close_key || close_attr
		
        exact_matches << base_key if exact_match
        close_matches << base_key if close_match
      end

      { exact: exact_matches, close: close_matches }
    end
	
	def self.query_keys(query_name, rtrn_close = false, number_of_chops = 3)
      
	  chops_remaining = number_of_chops
	  search_results = nil
      exact_matches = []
      close_matches = []
  
      query_match = query_name.dup
	  
	        # Run at least once, then continue if target array is empty and we have attempts/length
      loop do
        # Perform the base search
        search_results = _attr_key_search(query_match)
        exact_matches  = search_results[:exact]
        close_matches  = search_results[:close]

        # Check if we should stop: either we found what we need, or we are out of retries
        target_found = rtrn_close ? !close_matches.empty? : !exact_matches.empty?
        break if target_found || chops_remaining <= 0 || query_match.length <= 3

        # Prepare for next iteration
        query_match.chop!
        chops_remaining -= 1
      end
	  
	  query_result = rtrn_close ? close_matches : exact_matches
	  return query_result
    end
	
	def self.has_key?(key_name)
	  target_keys = []
	  target_keys = query_keys(key_name, true)
	  query_result = !target_keys.empty?
	end

    # Factory method to find and create a single BaseStock instance
    def self.name(stock_name)
      stock_key = nil
      target_keys = BaseStock.query_keys(stock_name, true)
	  if target_keys.empty?
		return nil
	  end
	  
	  if target_keys.size == 1
	    stock_key = target_keys.first
	  
	  elsif target_keys.size > 1
	    target_keys.each do |target_key|
		  stock_data = @@base_stocks[target_key]
		  
		  key_str = clean_str(target_key)
		  name_str = clean_str(stock_data['stock-name'])
		  
		  cond_key_equals_name = (key_str == name_str)
		  cond_no_name = (!stock_data['stock-name'])
		  
		  if (cond_key_equals_name || cond_no_name)
		    stock_key = target_key
			break
		  end		  
		end
	  end
	  
	  new(stock_key)
    end

  	def self.key(stock_key)
	  return nil unless @@base_stocks[stock_key]
	  new(stock_key)
	end
  
    def self.get_volume_info(exact_stock_name, target_volume)
      target_keys = BaseStock.query_keys(exact_stock_name, false)
	  
      # Correctly mapping, sorting by volume descending, and freezing
      target_base_stocks = target_keys.map { |stock_key| send(:new, stock_key) }
                                      .sort_by(&:volume)
                                      .reverse
                                      .freeze

      last_target_index = target_base_stocks.size - 1
      volume_stock_info = []
      current_volume = 0
      remaining_volume = target_volume

      # Guard check for empty collection
      return [] if target_base_stocks.empty?

      while current_volume < target_volume
        # Reset info for each pass to recalculate the distribution
        volume_stock_info = []
      
        target_base_stocks.each_with_index do |base_stock, index|
          is_last_index = (index == last_target_index)    
          stock_volume = base_stock.volume
        
          # Guard against division by zero
          next if stock_volume.zero?

          qty_ratio = remaining_volume.to_f / stock_volume
          volume_stock_qty = is_last_index ? qty_ratio.ceil : qty_ratio.floor
        
          # Add the :quantity key to the info hash
		  if volume_stock_qty > 0
            _info = base_stock.base_info.merge(quantity: volume_stock_qty)
            volume_stock_info << _info
		  end

          current_volume = volume_stock_info.sum { |stock_info| stock_info[:volume] * stock_info[:quantity] }      
          remaining_volume = target_volume - current_volume
		  break if remaining_volume <= 0
        end
        break if remaining_volume <= 0
      end

      volume_stock_info
    end

    def initialize(stock_key)
	  super()
      @base_key = stock_key
      @raw_stock_data = @@base_stocks[stock_key]
      
      return unless @raw_stock_data
	  
      # @name represents the in-game string to interact with the object.
	  @name     = @raw_stock_data['stock-name']   || @base_key
      # @order_id represents stock id number used to order the item by number. 
	  # (Some items are purchased through order number, if it exists. 
	  # Others are purchased by name.
	  @order_id = @raw_stock_data['stock-number'] || nil
      # @volume is the amount of pieces/uses/parts within the item. Default is 1.
	  @volume   = @raw_stock_data['stock-volume'] || 1
	  # @value is the amount of copper the stock will cost. All @@base_stocks have value defined in the database.
      @value    = @raw_stock_data['stock-value']  || 1000
    end
	
	private_class_method :new

    def is_bulk?
	  key_str = @base_key.to_s
	  namevolume_str = "#{@name}#{@volume}".to_s	  
	  is_bulk = false
	  is_bulk = true if (key_str == namevolume_str)
	  
	  return is_bulk
	end
    
	# This is the hash format to be used for creating the Crafting Component.
    def base_info
	  _info = {
		info_type: 'base_stock',
	    base_key: @base_key, 
	    name: @name, 
	    order_id: @order_id, 
	    volume: @volume, 
	    value: @value, 
	    is_bulk: is_bulk?
	  }
	  
	  return _info
    end

    def to_s
