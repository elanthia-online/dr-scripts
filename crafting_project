    @material_components = []
    
    @required = { quantity: 1, volume: info[:required_volume] || 1 }
    
	@update_method = :_update_material!
	@verify_method = :determine_material_components!
    @needs_method = :_material_needs?
    @resolution_method = :_resolution_stack_material!
    determine_stack_method!	
  end
  
  private_class_method :new
  
  def determine_stack_method!
    @stack_method = (@@base_material == 'metal') ? :_stack_smelt_all! : :_stack_combine_all!
  end
  
  # builds @material_components from the @name InGame items found in the @@bag.
  def determine_material_components!
    @material_components = []
    determine_on_hand! # Determines the quantity of @name on hand (in the @@bag), verifies the class CraftingMaterial object.
    # we do not update yet as material_update will override the @on_hand[:quantity] determined by determine_on_hand!
	qty_on_hand = @on_hand[:quantity]
	
	# We use push (<<) here because we are reading the bag from top to bottom
    qty_on_hand.times { |index| @material_components << _compose_material_component!(index, true) } if qty_on_hand > 0

    update!
    volume_stock_components.each { |vol_comp| @material_components << vol_comp }
    update!
    self
  end

  def stack!
    send(@stack_method)
    update!
	self
  end

  def to_s
    header_str = super
    obj_str = []
    
	obj_str << header_str
	if @material_components.any?
	  are_children!(@material_components)
      CraftingSettings.up_tabs!(@material_components, 1)	
	  mat_comp_str = nest_string(@material_components)
	  obj_str << "material_components:"
      obj_str << "#{mat_comp_str}"
	end
	
    nest_string(obj_str)
  end

  def _update_material!
    @material_components.each do |mat_comp|
      mat_comp.update!
      mat_comp.override_name!(@name)
    end
    
    @on_hand[:quantity] = @material_components.sum { |mat_comp| mat_comp.on_hand[:quantity] }
    @on_hand[:volume]   = @material_components.sum { |mat_comp| mat_comp.on_hand[:volume] }
    @cost               = @material_components.sum { |mat_comp| mat_comp.cost }
    return self  
  end
  
    # Creates an individual verified material_component: CraftingComponent
  def _compose_material_component!(index = -1, in_bag = false)
    stow_item!(@name) if DRCI.in_hands?(@name) && in_bag
	
    nominal_group = index >= 0 ? _ordinal_name(index) : "my #{@name}"
	component_volume = __count_volume(nominal_group, in_bag) 
  
    mat_comp_info = {
	  base_key: "[ #{@name} on hand in #{@@bag.split(".").join(" ")} ] ",
      name: @name,
      volume: component_volume,
      quantity: 1,
      on_hand_quantity: 1,
      on_hand_volume: component_volume,
	  info_type: 'material_component'
    }
    
    material_component = CraftingComponent.compose(mat_comp_info)
    material_component.override_verified!
    material_component
  end
  
  def volume_stock_components
    
    volume_components = []
	vol_needed = __calculate_needed_volume
	return volume_components unless vol_needed > 0
	
	stock_search = @@material_name
	stock_search = 'yarn' if (@@base_material == 'knitted' && @@material_name == 'wool') # This is a specific override.
	# get_volume_info should return an array of _info hashes with the base_stock.base_info combined with the quantity needed.
	volume_stocks_info = Data::BaseStock.get_volume_info(stock_search, vol_needed)
	
	volume_stocks_info.each do |stock_info|
	  volume_components << CraftingComponent.compose(stock_info)
	end
	
	
	return volume_components
  end
  
  def _sort_material_components!
	update!
    # Sorts lowest to highest volumes.
    sorted_volumes = @material_components.map { |mat_comp| mat_comp.on_hand[:volume] }.uniq.sort
    return unless @on_hand[:quantity] > 1 # Does not need re-sorting if only 1 quantity on hand.
	
    until sorted_volumes.empty?
      target_volume = sorted_volumes.shift 
    
	
	  target_index = 0
      @material_components.each do |mat_comp|
        if mat_comp.on_hand[:volume] == target_volume
          __get_material_component!(target_index) 
          __stow_material_component! 
          break
        end
		target_index += 1
      end
    end
	
	@material_components
  end
  
  def __get_material_component!(index = 0)
    nominal_group = _ordinal_name(index)
	get_item!(nominal_group)	
	mat_comp = @material_components.delete_at(index)
	mat_comp
  end
  
  def __stow_material_component!
    if DRCI.in_hands?(@name)	  
	  @material_components.unshift(_compose_material_component!)
	  stow_item!(@name)
	end
  end
 
  def __count_volume(nominal_group = @name, in_bag = false)
    game_command  = "count #{nominal_group}"
	game_command += " in my #{@@bag}" if in_bag == true	
	command_result = DRC.bput(game_command, 'out (\d+) yards', 'out (\d+) pieces', 'About (\d+) volume')
	return command_result.scan(/\d+/).first.to_i
  end 
  
   # Should return true if any @material_components have DO NOT HAVE needs.
  def __ready_condition_mat_comps?
    update!
    !@material_components.any?(&:has_needs?)
  end
  
  # Should return true if the combined on_hand volume
  def __ready_condition_volume?
    update!
    @on_hand[:volume] >= @required[:volume]
  end
  
  # Should return true if the first material component in the array meets the volume requirements.
  def __ready_condition_first_component?
    update!
    result = @material_components[0].on_hand[:volume] >= @required[:volume]
	return result
  end
  
  def __stack_sort_condition_quantity?
    update!
    @on_hand[:quantity] > 1
  end
  
    # This is the @needs_method for CraftingMaterial
  def _material_needs?
    update!
	cond_1 = __ready_condition_mat_comps?
	cond_2 = __ready_condition_volume?
	cond_3 = __ready_condition_first_component?
    
    return true unless cond_1 && cond_2 && cond_3
	
	return false
  end

  def _resolution_stack_material!
    update!
    return self if __ready_condition_first_component?  
	# This should indirectly resolve ensuring the total volume on hand is needed.
	unless __ready_condition_mat_comps?
	  
	  unverify!	
	  @material_components.each { |mat_comp| mat_comp.resolve! if mat_comp.has_needs? }
	  verify!
      update!
	end
	
	# This should resolve ensuring that at least 1 of the material_components on_hand satisfies the volume.
	# If there is enough volume on_hand, and of there are more than 1 components on_hand, and if the first component DOES NOT have all the required volume...
	# ... stack them...
	if __ready_condition_volume? && __stack_sort_condition_quantity? && !__ready_condition_first_component?
	  
	  unverify!	
	  stack!
      verify!
      update!
	end
	
	# If there is enough volume on_hand, and of there are more than 1 components on_hand, and if the first component DOES NOT have all the required volume...
    # ... sort them (by greatest to least volume)
	if __ready_condition_volume? && __stack_sort_condition_quantity? && !__ready_condition_first_component?
      
	  unverify!	
	  _sort_material_components!
      verify!
      update!
	end

    return self
  end
  
  def _stack_combine_all!
    
    return unless get_item!(@name)
    @material_components = []
    
    loop do 
      get_item!(@name)
      case DRC.bput("combine", "You combine .* together", "must be holding both")
      when "You combine .* together"
        result = get_item!(@name)
        break if result.include?("I could not find") 
      when "must be holding both"
        break
      end
    end
  
    stow_items_in_hand!
	
	@on_hand[:verified] = false # Invalidates the verfication status if script executes.
    return self	
  end
  
  def _stack_smelt_all!
    crucible = {
	  count:  { current: 0, max: 22  },
	  volume: { current: 0, max: 210 }
	}
    # Finds an empty crucible and sets the initial crucible stats.
    DRCC.find_empty_crucible(@@hometown) 
    
	# Checks how many @name are currently on_hand in the @@bag.
	on_hand_item_count = DRCI.count_items_in_container(@name, @@bag)
    # Loading the crucible.
    on_hand_item_count.times do
      
	  break unless get_item!(@name)
	  
	  ingot_volume = __count_volume
	  # Compares against crucible's max limits.
      if ( crucible[:count][:current] + 1 > crucible[:count][:max] ) || ( crucible[:volume][:current] + ingot_volume > crucible[:volume][:max] )
	    stow_item!(@name)
		break
	  end
	  
	  # Puts the @name into the crucible.
      case DRC.bput("put my #{@name} in crucible", "You put", "What were", "smelting such a volume of metal", "smelting so many metal pieces")
      when "You put"
        crucible[:volume][:current] += ingot_volume
        crucible[:count][:current]  += 1
      when "What were" 
        break
      when "smelting such a volume of metal", "smelting so many metal pieces"
        stow_item!(@name)
        break
      end
      
	  # Checks crucibles current theoretical contents against their maximums.
      break if ( crucible[:volume][:current] >= crucible[:volume][:max] ) || ( crucible[:count][:current] >= crucible[:count][:max] )
    end
	
	
    crucible_contents = DRC.bput("rummage /C #{@name.split.last} in crucible", /^You rummage .*/, /That would accomplish nothing/)
    crucible_item_count = crucible_contents.scan(/ #{@name}\W/).size
 
  
    # Smelts the @name in the crucible if there is more than one @name inside.  
    if crucible_item_count > 1
      DRC.wait_for_script_to_complete('smelt')
    elsif crucible_item_count == 1
      DRC.bput("get #{@name} from the crucible", "You get", "What were")
    end
    
    stow_item!(@name)
	
    @material_components = []
	@on_hand[:verified] = false # Invalidates the verfication status if script executes.
    return self
  end
  
end

class CraftingInventory < CraftingSettings
  attr_reader :crafting_material, :recipe_components, :discipline_components

  def initialize
    super()
    # 1. Material probes immediately via from_Base -> determine_on_hand!
    @crafting_material = CraftingMaterial.from_Base	
	@recipe_components = CraftingComponent.compose_recipe_components
	@discipline_components = CraftingComponent.compose_discipline_components
  end
  
  public_class_method :new

  def has_needs?
    need = false
	inventoried_components.each do |comp|
	  need = true if comp.has_needs?
	end
	return need
  end
  
  # NOT EXECUTED ON INITIALIZATION
  def resolve_all!
    needed_cash = [total_cost, 5000].max
    DRCM.ensure_copper_on_hand(needed_cash, SETTINGS, @@hometown)
	DRCT.walk_to(@@base_discipline.idle_room)
	# @crafting_material.resolve! should handle the resolution of internal components as well as the @crafting_material stacking.
    @crafting_material.resolve! if @crafting_material && @crafting_material.respond_to?(:resolve!)
	#@part_components.each { |part_comp| part_comp.resolve! } if @part_components.any? && @part_components[0].respond_to?(:resolve!)
    @recipe_components.each { |recipe_comp| recipe_comp.resolve! } if @recipe_components.any? && @recipe_components[0].respond_to?(:resolve!)
    
	@disipline_components.each { |disc_comp| disc_comp.resolve! } if @discipline_components.any? && @discipline_components[0].respond_to?(:resolve!)
	
	#This is the catchall for all individual root components. This does not resolve the stacking in CraftingMaterials.
	inventoried_components.each do |comp|
      comp.resolve! if comp.has_needs?
    end
	
	verify_all!	
	self
  end
  
  def verify_all!
    @crafting_material&.verify! unless @crafting_material&.is_verified?
	#@part_components.each { |part_comp| part_comp&.verify! unless part_comp&.is_verified? } unless @part_components.empty?
	@recipe_components.each { |recipe_comp| recipe_comp&.verify! unless recipe_comp&.is_verified? } unless @recipe_components.empty?
	@discipline_components.each { |disc_comp| disc_comp&.verify! unless disc_comp&.is_verified? } unless @discipline_components.empty?
    self
  end

  def inventoried_components
    #[@crafting_material, *@part_components, *@discipline_components].compact
	[@crafting_material, *@recipe_components, *@discipline_components].compact
  end

  def total_cost
    inventoried_components.sum { |c| c.has_needs? ? (c.cost || 0) : 0 }
  end
  
  def to_s
    obj_str = [""]
	
	obj_str << "Craft Bag:  [ #{@@bag.split(".").join(" ")} ]" if @@bag
    obj_str << "Craft Belt:  [ #{@@belt} ]" if @@belt
	
	
    if @crafting_material
	  are_children!(@crafting_material)
	  obj_str << "Crafting Material:"
	  obj_str << "#{@crafting_material}"
	end
	
    if @recipe_components.any?
	  are_children!(@recipe_components)
	  obj_str << "Recipe Components:"
	  obj_str << "#{nest_string(@recipe_components)}"
    end
	
	if @discipline_components.any?
	  are_children!(@discipline_components)
	  obj_str << "Discipline Components:"
	  obj_str << "#{nest_string(@discipline_components)}"
	end
	
	nest_string(obj_str)
  end
  
end

module CraftingMethod
  class CraftingProduct < CraftingSettings
    class << self
      attr_accessor :script_name, :script_arguments

      def script_name
        @script_name || 'unknown_script'
      end

      def script_arguments
        set_config if @script_arguments.nil? || @script_arguments.empty?
        @script_arguments || []
      end

      def lich_script_config
        [script_name, script_arguments]
      end

      def craft!
        # This ensures fresh data from the inventory is used right before execution.
        self.set_config 
        DRC.wait_for_script_to_complete(*lich_script_config)
      end
      
      def set_config
        raise "Must implement set_config in subclass"
      end

      def to_s
        "#{self.name.split('::').last}: {  #{script_name}, #{script_arguments}  }"
       end
    end
  end

