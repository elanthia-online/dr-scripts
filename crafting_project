    def determine_types!
      @skill_type = nil
	  @discipline_type = nil
	  
      return unless @type
      
      @discipline_type = @type.downcase.strip
      BASE_SKILLS.each do |skill_group, disciplines|
        if disciplines.include?(@discipline_type)
          @skill_type = skill_group
          break
        end
      end
      @skill_type
    end
	
	def new_class_base_material!
	  @base_material = BaseMaterial.from_BaseRecipe(self)
	end

    def determine_base_material!
      mat_index = 0
      non_default_index = false
      recipe_name = @name.to_s

      # Sets the @discipline_type materials, if it exists in @@crafting_materials.
      material_types = BASE_MATERIALS[@discipline_type] || []

      # First checks to see if the material name is present in the recipe name.
      if ( !material_types.empty? && material_types.size > 1 )
        material_types.each_with_index do |disc_material, type_index|
          mat_string = "\s#{disc_material}\s"
	      if recipe_name.include?(mat_string)
	        mat_index = type_index
	        non_default_index = true
	        break
	      end
        end	
      end

      # Then checks to see if the first compare caught the correct base_material.
      unless (non_default_index == true)
        case @discipline_type
        when 'tailoring'
          if [1, 2, 3, 4].include?(@chapter)
	        mat_index = 0 # Cloth
	        non_default_index = true
	      elsif (@chapter == 5)
	        mat_index = 1 # Yarn
	        non_default_index = true
	      elsif [7, 8 , 9, 10].include?(@chapter)
	        mat_index = 2 # Leather
	        non_default_index = true
	      end
        when 'carving'
	      if [1, 2, 3, 4].include?(@chapter)
	        mat_index = 0 # Stone
	        non_default_index = true
	      elsif [6, 7, 8, 9, 10]
	        mat_index = 1 # Bone
	        non_default_index = true
	      end		
        end
      end
      @base_material = @raw_recipe_data['material'] || BASE_MATERIALS[@discipline_type][mat_index]
      return self
    end
	 
