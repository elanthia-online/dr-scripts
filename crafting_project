class CraftingComponent < CraftingSettings
  attr_reader   :base_key
  # Data::Base_Info
  attr_reader   :name, :order_id, :volume, :value, :room
  # Crafting  logic
  attr_reader   :required, :on_hand, :cost
  # Component_Methods execute these variables.
  attr_reader   :update_method, :verify_method, :needs_method, :resolution_method  
  
  def self.check_info_type(info_hash)
    type = info_hash[:info_type]
	return type
  end
  
  def self.is_basic_info?(info_hash)
    info_hash[:info_type] = 'basic'
  end
  
  def self.has_basic_info?(info_hash)
    has_keys?(info_hash, COMPONENT_INFO['basic'])
  end
  
  def self.is_stock_info?(info_hash)
    info_hash[:info_type] = 'base_stock'
  end
  
  def self.has_stock_info?(info_hash)
    has_keys?(info_hash, COMPONENT_INFO['base_stock'])
  end
  
  def self.is_part_info?(info_hash)
    info_hash[:info_type] = 'base_part'
  end
  
  def self.has_part_info?(info_hash)
    has_keys?(info_hash, COMPONENT_INFO['base_part'])
  end
  
  def self.is_crafting_material_info?(info_hash)
    info_hash[:info_type] = 'crafting_material'
  end
  
  def self.has_crafting_material_info?(info_hash)
    has_keys?(info_hash, COMPONENT_INFO['crafting_material'])
  end
  
  def self.is_material_component_info?(info_hash)
    info_hash[:info_type] = 'material_component'
  end
  
  def self.has_material_component_info?(info_hash)
    has_keys?(info_hash, COMPONENT_INFO['material_component'])
  end

  def self.quantify_info(info_array)
    return [] if info_array.nil? || info_array.empty?
    amalgamated = {}
    info_array.each do |comp_info|
      next if comp_info.nil?
      comp_info[:name] = comp_info[:name].to_s.downcase
      qty = comp_info.delete(:quantity) || comp_info.delete(:required) || 1
      identity = comp_info
      amalgamated[identity] = (amalgamated[identity] || 0) + qty
    end
    quantified_info = amalgamated.map { |info_hash, total_qty| info_hash.merge({ quantity: total_qty }) }
	return quantified_info
  end
  
  def self.compose_discipline_components
    discipline_components = []
    
    discipline_components_info = case @@discipline_type
                when 'blacksmithing', 'armorsmithing', 'weaponsmithing' 
                  @@base_discipline.blacksmithing
                when 'tailoring', 'artistry', 'jewelry making'          
                  @@base_discipline.tailoring
                when 'shaping', 'tinkering'                             
                  @@base_discipline.shaping
                when 'carving'                                          
                  @@base_discipline.carving
                when 'remedies', 'cooking', 'reactants'                 
                  @@base_discipline.remedies
                when 'artificing', 'binding', 'invoking'                
                  @@base_discipline.artificing
                end
	
	quantify_info(discipline_components_info).each { |comp_info| discipline_components << self.compose(comp_info) if comp_info }
	discipline_components.compact!
	discipline_components.each(&:verify!)
	discipline_components
  end
  
  def self.compose_recipe_components
    recipe_components = []
  
    parts_info      = quantify_info(@@base_recipe.parts)
	parts_info.each { |comp_info| recipe_components << self.compose(comp_info) if comp_info } unless parts_info.empty?
	
    alchemy_info    = quantify_info(@@base_recipe.alchemy)
	alchemy_info.each { |comp_info| recipe_components << self.compose(comp_info) if comp_info } unless alchemy_info.empty?
	
	enchanting_info = quantify_info(@@base_recipe.enchanting)
	enchanting_info.each { |comp_info| recipe_components << self.compose(comp_info) if comp_info } unless enchanting_info.empty?
  
    recipe_components.compact!
	recipe_components.each(&:verify!)
	recipe_components
  end
  
  # --- Low-Level Factory Methods ---
  # _stock_info is a outside constructor for a new BaseStock object. [BaseStock.name creates BaseStock.new()]
  # Creates a set of stock_info for a single BaseStock.
  def self.stock_comp_info(info)
    return {} if info.nil?
    info_hash = to_base_info(info)
	comp_info = nil	
	
    # Creates a fresh BaseStock from the provided [:name] key.
	base_stock = info_hash[:base_key] ? Data::BaseStock.key(info_hash[:base_key]) : Data::BaseStock.name(info_hash[:name])
    # BaseStocks.base_info [ base_key: string, name: string, order_id: number, volume: number, value: number, is_bulk: boolean ]
	stock_info = base_stock&.base_info
	
	return {} if stock_info.nil?
	
	is_bulk_stock = (info_hash[:is_bulk] == true) || base_stock.is_bulk?
	
	stock_room = @@base_discipline.stock_room
	bingots_room = @@base_discipline.bingots_room
	room_info = { room: is_bulk_stock ? bingots_room : stock_room }
	
	comp_info = stock_info.merge(room_info) if !stock_info.nil?
	# Returns an info_hash
	return comp_info
  end
  
  def self.part_comp_info(info)
    info_hash = to_base_info(info)	
	info_key = info_hash[:base_key] || info_hash[:name]	
	part_info = Data::BaseRecipePart.name(info_key)&.base_info
	return part_info
  end
  
  def self.compose(info)
    return nil if info.nil?
    base_info  = to_base_info(info)

    info_key  = base_info[:base_key]
	info_name = base_info[:name]
	
	part_info  = part_comp_info(base_info)

	stock_info = stock_comp_info(base_info)

    comp_info =  {
	  info_type: 'comp_info',
	  base_key:         part_info[:base_key] || stock_info[:base_key] || base_info[:base_key],
	  name:             part_info[:name]     || stock_info[:name]     || base_info[:name],
	  order_id:         part_info[:order_id] || stock_info[:order_id] || base_info[:order_id],
	  volume:                                   stock_info[:volume]   || base_info[:volume], 
	  value:                                    stock_info[:value]    || base_info[:value],
	  room:             part_info[:room]     || stock_info[:room]     || base_info[:room],
	  quantity:                                                          base_info[:quantity],
	  on_hand_quantity:                                                  base_info[:on_hand_quantity],
	  on_hand_volume:                                                    base_info[:on_hand_volume]
	}
	
    return send(:new, comp_info)
  end
  
  def self.valid_base_key?(info)
    info_hash = to_base_info(info)
	info_key = info_hash[:base_key] || info_hash[:name]
	
	contains_min_info       = is_basic_info?(info_hash)
	contains_craft_mat_info = is_crafting_material_info?(info_hash)
	contains_mat_comp_info  = is_material_component_info?(info_hash)
   
    is_base_stock = Data::BASE_STOCKS[info_key]
	is_base_part  = Data::BASE_PARTS[info_key]
	
    return true if contains_min_info || contains_craft_mat_info || contains_mat_comp_info || is_base_stock || is_base_part
	return false
  end

  # --- Instance ---
  def initialize(info)
    # 1. Set explicit defaults/system properties
    @component_class = "CraftingComponent"
    @verify_method = :determine_on_hand!
    @update_method = :_update_component!
    @needs_method = :_component_needs?
    @resolution_method = :_resolution_purchase_component!
    @cost = 0

    _base_key = info[:base_key] || info[:name]
    @base_key = _base_key.to_s.downcase.dup.freeze
    unless self.class.valid_base_key?(info)
      raise "Invalid Component: #{@base_key}. Not found in data tables and info is incomplete."
    end
	# 2. Define the "known" keys we handle specifically
    specific_keys = [:base_key, :name, :order_id, :volume, :value, :room, :quantity, :on_hand_quantity, :on_hand_volume]
	
    # 3. Handle specific assignments with logic/formatting
    @name     = info[:base_key] ? info[:name] : @base_key.dup
    @order_id = info[:order_id]
    @volume   = info[:volume] || 1
    @value    = info[:value]
    @room     = info[:room]

    @required = {
      quantity: info[:quantity] || 1,
      volume:   info[:volume]   || 1
    }

    @on_hand = {
      quantity: info[:on_hand_quantity] || 0,
      volume:   info[:on_hand_volume]   || 0,
      verified: false
    }

    # 4. Dynamic Assignment: Populate unspecified properties
    info.each do |key, value|
      unless specific_keys.include?(key)
        instance_variable_set("@#{key}", value)
        # Dynamically create a getter method if it doesn't exist
        self.class.send(:attr_reader, key) unless respond_to?(key)
      end
    end

    update!
  end
  
  private_class_method :new

  def determine_on_hand!
    
    name_array = @name.split
	item_noun = name_array.last
	match_patterns = []
	match_captures = []
    determined_quantity = 0
		
	match_string_0 = /(?:a|an|some)\s#{@name}/
	
	match_string_1a = /(?:a|an|some)\s#{item_noun}/
	match_string_1b = /(?:a|an|some)\s(?:\w+\s)?#{item_noun}/
	match_string_1c = /(?:a|an|some)\s(?:\w+\s)?(?:\w+\s)?#{item_noun}/
	
	match_string_2a = /(?:a|an|some)\s#{name_array.first}\s#{item_noun}/	
	match_string_2b = /(?:a|an|some)\s(?:\w+\s)?#{name_array.first}\s#{item_noun}/	
	match_string_2c = /(?:a|an|some)\s#{name_array.first}\s(?:\w+\s)?#{item_noun}/

	if (name_array.size == 1)
	  match_patterns = [match_string_1a, match_string_1b, match_string_1c]
	elsif (name_array.size == 2)
	  match_patterns = [match_string_2a, match_string_2b, match_string_2c]
	end
	
	
    contents = DRC.bput("rummage /C #{@name.split.last} in my #{@@bag}", /^You rummage .*/, /That would accomplish nothing/)
    
    case contents
    when /^You rummage .*/
	  retries = 0
	  match_patterns.each do |match_string|
	    
	    match_captures = contents.scan(match_string)
	    
        break unless match_captures.empty?
		retries += 1
	  end
	  determined_quantity = match_captures.size
    else
      determined_quantity = 0
    end

    
    
    @on_hand[:quantity] = determined_quantity
    @on_hand[:verified] = true
    self
  end

  def update!
    send(@update_method)
    return self
  end
  
  def override_name!(name)
    @name = name.downcase.to_s
    update!
    return self
  end

  def verify!
    send(@verify_method)
    update!
    return self
  end
  
  def unverify!
    @on_hand[:verified] = false
    return self
  end
  
  def is_verified?
    @on_hand[:verified]
  end
  
  def override_verified!(ovrd = true)
    @on_hand[:verified] = ovrd
    return self
  end

  def has_needs?
    update!
    send(@needs_method)
  end
  
  def resolve!
    send(@resolution_method) if has_needs?
    update!
    return self
  end

  def to_s
    _base_array = []
	_base_array << "base_key: #{@base_key}" if @base_key
    _base_array << "name: #{@name}"
    _base_array << "order_id: #{@order_id}" if @order_id
    _base_array << "room: #{@room}" if @room
    _base_array << "volume: #{@volume}" if @volume
    _base_array << "value: #{@value} copper" if @value
    
    base_str = "{" + _base_array.join(", ") + " }"
    obj_str = []  
    obj_str << ">#{_status_flag}"
    obj_str << "#{base_str}"
    obj_str << "    - required:  { quantity:#{@required[:quantity]}, volume:#{@required[:volume]} }"
    obj_str << "    - on_hand: { quantity:#{@on_hand[:quantity]}, volume:#{@on_hand[:volume]} }"
    obj_str << "    - cost: #{@cost} copper" if @cost
      
    return nest_string(obj_str)
  end  

  def _ordinal_name(index = 0)
    min_maxed = [[index, 0].max , ORDINAL.size].min
    "#{ORDINAL[min_maxed]} #{@name}"    
  end

  def _update_component!
    @on_hand[:volume] = @on_hand[:quantity] * (@volume || 0)
    @cost = @value ? @value * __calculate_needed_quantity : 0    
    self    
  end
  
  def __calculate_needed_quantity
    [0, @required[:quantity] - @on_hand[:quantity]].max
  end
  
  def __calculate_needed_volume
    [0, @required[:volume] - @on_hand[:volume]].max
  end

  def _component_needs?    
    @on_hand[:quantity] < @required[:quantity] || @on_hand[:volume] < @required[:volume]
  end

  def _resolution_purchase_component!
    return unless @value
    _needed_quantity = __calculate_needed_quantity
    DRCM.ensure_copper_on_hand(@cost, SETTINGS, @@hometown)
    
    _needed_quantity.times do
      @order_id && @room ? DRCT.order_item(@room, @order_id) : DRCT.buy_item(@room, @name)
      stow_items_in_hand!
    end
    
    @on_hand[:verified] = false
    self
  end

  def _status_flag
    return "[READY]" unless has_needs?
    return "[MISSING]" if @on_hand[:quantity] == 0
    "[INCOMPLETE]"
  end
end

