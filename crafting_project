class CraftingProject < CraftingSettings

  attr_reader :crafting_inventory # Instance of CraftingInventory
  attr_reader :crafting_method    # This will hold the Product CLASS (e.g. CraftingMethod::ForgingProduct)

  def initialize(recipe_name, material_name = nil)
    super()
    @base_tab = 1
	@report_number = 0
    DRC.message("CraftingProject Initializing: #{recipe_name} with #{material_name || 'default material'}")
    
    # 1. Set the Global Recipe state
    CraftingSettings.set_recipe!(recipe_name)
    unless @@base_recipe && @@base_recipe.raw_recipe_data
      DRC.message("CraftingProject: Recipe #{recipe_name} not found. Exiting...")
      exit
    end

    # 2. Setup Disciplines and Materials
    CraftingSettings.set_discipline!
    CraftingSettings.set_material_name!(material_name)
    
    # 3. Initialize Inventory
    @crafting_inventory = CraftingInventory.new
    
    # 4. Resolve the correct CraftingMethod subclass
    determine_crafting_method!
    
  end
  
  public_class_method :new
  
  def has_needs?
    @crafting_inventory.has_needs?
  end
  
  def resolve!
    @crafting_inventory.resolve_all!
    DRC.message("### @crafting_inventory.resolve_all! unsuccessful... ###") if @crafting_inventory.has_needs?
    self  
  end
   
  def determine_crafting_method!
    # Logic to map skill_type to the targeted subclass in the CraftingMethod module
    @crafting_method = case @@skill_type
                         when 'forging'     then CraftingMethod::ForgingProduct
                         when 'outfitting'  then CraftingMethod::OutfittingProduct
                         when 'engineering' then CraftingMethod::EngineeringProduct
                         when 'alchemy'     then CraftingMethod::AlchemyProduct
                         when 'enchanting'  then CraftingMethod::EnchantingProduct
                         else
                           DRC.message("Warning: No CraftingMethod found for skill_type: #{@@skill_type}")
                           nil
                       end
    @crafting_method.set_config
	self
  end
   
  def craft!
    DRCT.walk_to(@@base_discipline.idle_room)
    if @crafting_method
      
      @crafting_method.craft! # Calls the class method in the subclass
    else
      DRC.message("Error: Cannot craft, no crafting_method set.")
    end
	self
  end
  
  def report(report_heading = 'Summary')
    @report_number += 1
    are_children!(@crafting_inventory) if @crafting_inventory

    _str = ["*** Crafting Project Report ##{@report_number}: #{report_heading} ***"]
	_str << SOLID_LINE
    _str << "Crafting Town:  [ #{@@hometown.capitalize} ]"
    _str << "#{@crafting_method.to_s}" if @crafting_method
	_str << SOLID_LINE
    _str << "Recipe Name:  [ #{@@recipe_name} ]"
    _str << "Crafting Type:  [ #{@@skill_type.capitalize} - Book of #{@@discipline_type.capitalize}, Chapter #{@@recipe_chapter} ]"   
    _str << "Material Base:  [ #{@@recipe_volume} units of #{@@base_material} material, #{@@material_name} ]" if @@base_material 
	_str << "Craft Product:  [ #{@@product_noun} ]"
	_str << SOLID_LINE
    _str << "Crafting Inventory >>  #{@crafting_inventory.to_s}" if @crafting_inventory
	_str << SOLID_LINE
	
	return nest_string(_str)
  end
end

class CraftingLibrary
  attr_reader :args

  def initialize(args)
    @args = args
  end

  # Orchestrates the database query based on the parsed @args
  def query
    attr = @args.attribute
    val  = @args.value

    case @args.database
    when 'recipes' then list_recipes(attr, val)
    when 'stocks'  then list_stocks(attr, val)
    when 'parts'   then list_parts(attr, val)
    else "Unknown database: #{@args.database}"
    end
  end

  def list_recipes(attr = nil, val = nil)
    generic_list_filter('Recipe', Data::BASE_RECIPES.crafting_recipes.freeze, 'name', attr, val)
  end

  def list_stocks(attr = nil, val = nil)
    generic_list_filter('Stock', Data::BASE_CRAFTING.stock.freeze, 'stock', attr, val)
  end

  def list_parts(attr = nil, val = nil)
    generic_list_filter('Part', Data::BASE_CRAFTING.recipe_parts.freeze, 'part', attr, val)
  end

  def generic_list_filter(title, collection, label_key, attribute, attribute_value)
    attr_str = attribute.to_s.downcase.strip

    # 1. Handle "index" keyword for specific record lookup
    if !attr_str.empty? && "index".start_with?(attr_str)
      return list_item_by_index(title, collection, attribute_value.to_i)
    end

    # 2. Handle Attribute/Key list request (partial match for attr, key, attributes, keys)
    is_attr_cmd = %w[attr key attributes keysof].any? { |cmd| cmd.start_with?(attr_str) }
    if !attr_str.empty? && is_attr_cmd
      return list_available_attributes(title, collection)
    end

    # 3. Handle Unique Value list (e.g. LIST parts hometown)
    if attribute && (attribute_value.nil? || attribute_value.to_s.empty?)
      return list_unique_attribute_values(title, collection, attribute)
    end

    # 4. Filtered List Logic
    results = []
    collection.each_with_index do |item, index|
      info_hashes = []
      display_name = ""

      case @args.database
      when 'recipes'
        info_hashes = [item]
        display_name = item[label_key]
      when 'stocks'
        display_name = item[0]
        h = item[1].dup
        h['stock'] = item[0]
        info_hashes = [h]
      when 'parts'
        display_name = item[0]
        item[1].each do |town, data|
          h = data.dup
          h['part'] = item[0]
          h['hometown'] = town
          info_hashes << h
        end
      end

      matched_value = nil
      match = info_hashes.any? do |h|
        if attribute && attribute_value
          target_data = h[attribute]
          search_term = attribute_value.to_s.downcase.strip
          if target_data.to_s.downcase.include?(search_term)
            matched_value = target_data
            true
          else
            false
          end
        else
          true
        end
      end

      if match
        results << {
          index_tag: "#{title}[#{index}]",
          label_key: "[:#{label_key}]",
          label_val: "'#{display_name}'",
          attr_key:  attribute ? "[:#{attribute}]" : nil,
          attr_val:  matched_value ? "'#{matched_value}'" : nil
        }
      end
    end

    return "#{title} List:\nNo matches found.\n" if results.empty?

    hide_attr_suffix = (attribute.to_s.downcase == label_key.to_s.downcase)
    max_idx   = results.map { |r| r[:index_tag].length }.max
    max_label = results.map { |r| r[:label_key].length }.max
    max_val   = results.map { |r| r[:label_val].length }.max
    max_attr  = results.map { |r| r[:attr_key].to_s.length }.max

    list = ["#{title} List:"]
    list << "(Filter: [:#{attribute}] =~ /#{attribute_value}/i)" if attribute && attribute_value
    
    results.each do |r|
      line = ">> #{r[:index_tag].ljust(max_idx)} : #{r[:label_key].ljust(max_label)} => #{r[:label_val].ljust(max_val)}"
      if !hide_attr_suffix && r[:attr_key] && r[:attr_val]
        line += " | #{r[:attr_key].ljust(max_attr)} => #{r[:attr_val]}"
      end
      list << line
    end
    list.join("\n") + "\n"
  end

  def list_item_by_index(title, collection, index)
    items = collection.is_a?(Hash) ? collection.to_a : collection
    entry = items[index]
    return "Index #{index} not found in #{title} database." if entry.nil?

    label = (@args.database == 'recipes' ? entry['name'] : entry[0])
    list = ["Detailed Report for #{title}[#{index}]: '#{label}'"]

    case @args.database
    when 'recipes'
      data_hash = entry
      max_k = data_hash.keys.map { |k| k.to_s.length }.max + 1
      data_hash.keys.sort.each { |k| list << "  [:#{k.to_s.ljust(max_k)}] => #{data_hash[k].inspect}" }
    when 'stocks'
      data_hash = entry[1]
      list << "  stock: '#{entry[0]}'"
      max_k = data_hash.keys.map { |k| k.to_s.length }.max + 1
      data_hash.keys.sort.each { |k| list << "    [:#{k.to_s.ljust(max_k)}] => #{data_hash[k].inspect}" }
    when 'parts'
      list << "  part: '#{entry[0]}'"
      hometown_hash = entry[1]
      hometown_hash.keys.sort.each do |town|
        list << "  hometown: '#{town}'"
        data = hometown_hash[town]
        max_k = data.keys.map { |k| k.to_s.length }.max + 1
        data.keys.sort.each { |k| list << "    [:#{k.to_s.ljust(max_k)}] => #{data[k].inspect}" }
      end
    end
    list.join("\n") + "\n"
  end

  def list_available_attributes(title, collection)
    return "Database is empty." if collection.empty?
    key_counts = Hash.new(0)
    total_items = 0

    collection.each do |item|
      info_hashes = []
      case @args.database
      when 'recipes' then info_hashes = [item]
      when 'stocks'
        h = item[1].dup
        h['stock'] = item[0]
        info_hashes = [h]
      when 'parts'
        item[1].each do |town, data|
          h = data.dup
          h['part'] = item[0]
          h['hometown'] = town
          info_hashes << h
        end
      end
      
      info_hashes.each do |h|
        next unless h
        total_items += 1
        h.keys.each { |k| key_counts[k] += 1 }
      end
    end

    universal_keys = []
    optional_keys = []
    key_counts.each do |key, count|
      count >= total_items ? universal_keys << key : optional_keys << key
    end

    list = ["Available Attributes for #{title}:", "(* indicates optional key)"]
    universal_keys.sort.each { |key| list << ">> :#{key}" }
    optional_keys.sort.each { |key| list << ">> :#{key} (*)" }
    list.join("\n") + "\n"
  end

  def list_unique_attribute_values(title, collection, attribute)
    unique_values = []
    collection.each do |item|
      info_hashes = []
      case @args.database
      when 'recipes' then info_hashes = [item]
      when 'stocks'
        h = item[1].dup
        h['stock'] = item[0]
        info_hashes = [h]
      when 'parts'
        item[1].each do |town, data|
          h = data.dup
          h['part'] = item[0]
          h['hometown'] = town
          info_hashes << h
        end
      end
      
      info_hashes.each do |h|
        val = h[attribute]
        if val.is_a?(Array)
          unique_values.concat(val.map { |v| v.to_s.downcase })
        elsif val
          unique_values << val.to_s.downcase
        end
      end
    end

    unique_values = unique_values.map(&:strip).reject(&:empty?).uniq.sort
    list = ["Unique values for #{title}[:#{attribute}]:"]
    unique_values.each { |v| list << ">> '#{v}'" }
    list << "No values found." if unique_values.empty?
    list.join("\n") + "\n"
  end
end

class LichCraftingProject
  attr_reader :args, :project, :library, :report
  HELP_NOTE = "\n   - "
  
  PRODUCE_HELP = (
    HELP_NOTE + 'Full Execution of Crafting Project'
  )
  
  PREPARE_HELP = (
    HELP_NOTE + 'PREPARE is meant for users to check for, purchase, and PREPARE their own inventory for necessary Crafting Components.'  + 
    HELP_NOTE + 'DOES RESOLVE missing components, DOES NOT CRAFT the project. '
  )
  
  PLAN_HELP = (
   HELP_NOTE + 'PLAN is meant for users to check their own inventory for necessary Crafting Components.' +
   HELP_NOTE + 'DOES NOT RESOLVE missing components.'
  )
  
  LIST_HELP = ( 
    HELP_NOTE + "Example usage:" + 
	HELP_NOTE + "LIST 'recipes'                       ->  will list all the recipes in the database." + 
	HELP_NOTE + "LIST 'recipes' 'attribute'           ->  will list all the attribute keys for recipes." + 
	HELP_NOTE + "LIST 'recipes' 'type'                ->  will list all the different possible values for recipe type." + 
	HELP_NOTE + "LIST 'recipes' 'type' 'artificing'   ->  will list all the recipes whose type is artificing." + 
	HELP_NOTE + "LIST 'recipes' INDEX <index_number>  ->  will retrieve the database element values for recipe of index value <index_number>"
  )

  # Argument definition structure for parse_args (Lich.rb method)
  LICH_ARGS_DEF = [
    [
      { name: 'PRODUCE', regex: /PRODUCE/i, optional: false, variable: false, description: 'TIER 3 - Full Execution - PLAN, PREPARE and PRODUCE the full Crafting Project (Crafts the Product)'},
      { name: 'recipe_name', display: 'recipe name', regex: /^[A-z\s\-']+$/i, optional: false, variable: true, description: 'The exact name of the recipe, between double-quotes. ("some blister cream", "a metal chain hauberk", etc)' },
      { name: 'material', regex: /\w+/i, optional: true, variable: true, description: 'The specific material.' + PRODUCE_HELP }
    ],
	[
      { name: 'PREPARE', regex: /PREPARE/i, optional: false, variable: false, description: 'TIER 2 - PLAN, purchase and PREPARE the components for the Crafting Project.'},
      { name: 'recipe_name', display: 'recipe name', regex: /^[A-z\s\-']+$/i, optional: false, variable: true, description: 'The exact name of the recipe, between double-quotes.("some blister cream", "a metal chain hauberk", etc)'},
      { name: 'material', regex: /\w+/i, optional: true, variable: true, description: 'The specific material.' + PREPARE_HELP }, 
    ],
	[
      { name: 'PLAN', regex: /PLAN/i, optional: false, variable: false, description: 'TIER 1 - Determines necessary Crafting Components for a given recipe, checking to see which are already on hand.' },
      { name: 'recipe_name', display: 'recipe name', regex: /^[A-z\s\-']+$/i, optional: false, variable: true, description: 'The exact name of the recipe, between double-quotes. ("some blister cream", "a metal chain hauberk", etc)'},
      { name: 'material', regex: /\w+/i, optional: true, variable: true, description: 'The specific material.' + PLAN_HELP }
    ],
    [
      { name: 'LIST', regex: /LIST/i, optional: false, variable: false, description: 'Query the crafting databases.'},
      { name: 'database', options: %w[recipes stocks parts], optional: false, variable: true, description: 'Which database to query.' },
      { name: 'attribute', regex: /\w+/i, optional: true, variable: true, description: 'Filter by <attribute> || INDEX.'},
      { name: 'value', regex: /\w+/i, optional: true, variable: true, description: 'attribute: <value> to match || INDEX <value> to retrieve'+ LIST_HELP}
    ]
  ]
  def initialize
    # parse_args is provided by Lich.rb environment
    @args = parse_args(LICH_ARGS_DEF)

    plan_project!    if @args.PRODUCE || @args.PREPARE || @args.PLAN	  
	prepare_project! if @args.PRODUCE || @args.PREPARE	  
	produce_project! if @args.PRODUCE

    determine_list!  if @args.LIST

    DRC.message("No valid command provided. Use PRODUCE, PLAN, PREPARE or LIST.") unless _executable_command?
    DRC.message("...Done.")
  end
  
  def _executable_command?
    !!(@args.PRODUCE || @args.PREPARE || @args.PLAN || @args.LIST)
  end

  def prepped?
    return false unless @project
    is_ready = !@project.has_needs?
    DRC.message("Project Ready? #{is_ready}")
    !!(is_ready)
  end

  def plan_project!
    @project = CraftingProject.new(@args.recipe_name, @args.material)
    project_report('Planning Stage')
	prepped?
	return @project
  end
  
  def prepare_project!
    @project.resolve!
	project_report('Preparation Stage')
	prepped?
	return @project
  end  

  def produce_project!    
    @project.craft! if prepped?
	project_report('Production Stage')
	return @project
  end

  def project_report(report_heading = 'Crafting Summary')
    DRC.message("Project not found or initialized.") unless @project
    DRC.message(@project.report(report_heading)) if @project
  end
  
  def determine_list!
    @library = CraftingLibrary.new(@args)
	DRC.message(@library.query) if @library
  end
end

LichCraftingProject.new
