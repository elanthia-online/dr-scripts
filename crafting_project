    end
	
  end

  class BaseRecipePart < Default
    @@base_recipe_parts = BASE_CRAFTING.recipe_parts.freeze
    @@hometown          = Data::HOMETOWN
    
    attr_reader :raw_part_data, :name, :order_id, :room

    def self._basic_key_search(query_name)
      # Assuming Data::BASE_PARTS and clean_str are defined in the broader scope
      source_database = Data::BASE_PARTS
      exact_matches = []
      close_matches = []
	  
	  query_str = clean_str(query_name)

      # Iterate through the entire database
      source_database.each do |key, _value|
        # Using clean_str as provided in your snippet
        key_str = clean_str(key)
        exact_matches << key if (key_str == query_str)
        close_matches << key if (key_str.include?(query_str))
      end

      { exact: exact_matches, close: close_matches }
    end

    # Primary function to handle return types and the recursive "chopping" logic
    def self.query_keys(query_name, rtrn_close = false, number_of_chops = 3)
      
	  chops_remaining = number_of_chops
	  search_results = nil
      exact_matches = []
      close_matches = []
  
      query_match = query_name.dup
  
      # Run at least once, then continue if target array is empty and we have attempts/length
      loop do
        # Perform the base search
        search_results = _basic_key_search(query_match)
        exact_matches = search_results[:exact]
        close_matches = search_results[:close]

        # Check if we should stop: either we found what we need, or we are out of retries
        target_found = rtrn_close ? !close_matches.empty? : !exact_matches.empty?
        break if target_found || chops_remaining <= 0 || query_match.length <= 3

        # Prepare for next iteration
        query_match.chop!
        chops_remaining -= 1
      end
	  
	  query_result = rtrn_close ? close_matches : exact_matches
	  
	  return query_result
    end
	
	def self.has_key?(key_name)
	  target_keys = []
	  target_keys = query_keys(key_name, true)
	  !target_keys.empty?
	end

    def self.name(part_name)
	  target_keys = BaseRecipePart.query_keys(part_name, true)
	  if target_keys.empty?
	    
	    return nil
	  end
	  part_key = target_keys.sort.first
      new(part_key)
    end
    
	def self.key(part_key)
	  return nil unless @@base_recipe_parts[part_key]  
	  new(part_key)
	end

    def initialize(part_key)
	  super()
	  @base_key = part_key
      @name = @base_key
      @raw_part_data = @@base_recipe_parts.dig(@name, @@hometown)
      return unless @raw_part_data

      @order_id = @raw_part_data['part-number']
      @room    = @raw_part_data['part-room']
    end
	
	private_class_method :new
	
	def base_info
	  _info = { 
		info_type: 'base_part',
	    base_key: @base_key, 
		name: @name, 
		order_id: @order_id,
		room: @room
		}
	  return _info
	end
	
  end

end

